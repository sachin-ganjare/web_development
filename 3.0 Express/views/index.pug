//- index.pug
//- Demo Pug template showing a full page layout

doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Pug Demo Page

    style.
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
        background: #f5f7fa;
        color: #222;
      }
      header, footer {
        background: #111827;
        color: #fff;
      }
      header a, footer a { color: #93c5fd; text-decoration: none; }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.5rem;
      }
      nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 1rem;
      }
      main {
        background: #fff;
        margin: 2rem auto;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
      }
      article {
        padding: 2rem;
      }
      article h2 { margin-top: 0; }
      aside {
        background: #f1f5f9;
        padding: 1.5rem;
        border-top: 1px solid #e5e7eb;
      }
      footer {
        margin-top: 3rem;
        font-size: 0.9rem;
      }

  body
    //- =====================
    //- Header
    //- =====================
    header
      .container
        h1 Demo Website
        nav
          ul
            li: a(href="#") Home
            li: a(href="#") Articles
            li: a(href="#") About
            li: a(href="#") Contact

    //- =====================
    //- Main Content
    //- =====================
    main.container
      //- Article section
      article
        header
          h2 Building Pages with Pug
          p
            | Published on 
            time(datetime="2026-01-16") January 16, 2026
            |  · by Demo Author

        p
          | Pug is a clean, whitespace-sensitive templating language for HTML. 
          | It helps you write reusable, readable templates with less noise.

        p
          | This demo shows a typical page structure with a header, navigation, 
          | main article content, a sidebar, and a footer.

        h3 Example List
        ul
          li Simple syntax
          li Reusable layouts
          li Easy nesting

        h3 Example Code Block
        pre
          code.
            html
              head
                title My Page
              body
                h1 Hello from Pug

      //- Sidebar / Aside content
      aside
        h3 Related Links
        ul
          li: a(href="#") Pug Documentation
          li: a(href="#") Express.js Guide
          li: a(href="#") Template Best Practices

        h3 Newsletter
        form(action="#", method="post")
          label(for="email") Email address
          br
          input#email(type="email", name="email", placeholder="you@example.com")
          br
          button(type="submit") Subscribe

    //- =====================
    //- Footer
    //- =====================
    footer
      .container
        p © 2026 Demo Website. All rights reserved.
        p
          | Built with 
          a(href="https://pugjs.org") Pug
          |  · 
          a(href="#") Privacy Policy
          
